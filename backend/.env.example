# ContentAgent 后端环境配置
# 复制此文件为 .env 并填入实际配置

# LLM 配置（DeepSeek）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# SiliconFlow Embedding API（用于向量生成）
# 申请地址: https://siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_api_key

# 数据库配置（可选）
DATABASE_URL=mysql+pymysql://content_agent:content123@localhost:3306/content_agent

# Qdrant 向量数据库（可选）
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 服务配置
DEBUG=true
LOG_LEVEL=INFO
